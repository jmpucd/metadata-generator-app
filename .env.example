# Copy this to .env and fill in your values
OLLAMA_TOKEN=your-ollama-bearer-token-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Backend: ollama | claude | qwen_vl | mock
MODEL_BACKEND=ollama

# Optional overrides (defaults shown)
# OLLAMA_BASE_URL=https://samwise.library.ucdavis.edu/ollama
# OLLAMA_MODEL=qwen2.5vl:32b
# CLAUDE_MODEL=claude-opus-4-7
# IMAGES_DIR=/digitization/Metadata-Generator-App/images/incoming
# OLLAMA_IMAGE_MAX_PX=2048
# OLLAMA_IMAGE_QUALITY=85
